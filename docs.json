{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Imitari Docs",
  "colors": {
    "primary": "#ad5bff",
    "light": "#ad5bff",
    "dark": "#ad5bff"
  },
  "favicon": {
    "light": "/favicon.svg",
    "dark": "/favicon.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ],
        "icon": "library-big"
      },
      {
        "tab": "Changelog",
        "icon": "asterisk",
        "pages": [
          "untitled-page"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "linkedin": "https://x.com/juniusstudio"
    }
  },
  "description": "Discover how to simplify storage, processing, and delivery with Imitari's powerful, developer-friendly infrastructure.",
  "appearance": {
    "default": "system"
  },
  "icons": {
    "library": "lucide"
  },
  "interaction": {
    "drilldown": false
  },
  "seo": {
    "indexing": "all"
  },
  "fonts": {
    "family": "Satoshi",
    "weight": 500,
    "source": "https://dash.imitari.app/fonts/Satoshi-Variable.woff2",
    "format": "woff2"
  },
  "background": {
    "color": {
      "dark": "#0f0c11"
    },
    "decoration": "grid"
  },
  "metadata": {
    "timestamp": false
  }
}
